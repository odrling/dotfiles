# vi: ft=xcompose

# include global configuration
include "%L"

# Emoji
<Multi_key> <less> <3>                               : "♥"   # basic heart
<Multi_key> <less> <less> <3>                        : "❤️"  # red heart
<Multi_key> <asterisk> <asterisk>                    : "✨"  # sparkles

# Misc
<Multi_key> <minus> <minus>: "—" # em-dash
<Multi_key> <e> <m>: "—" # em-dash
<Multi_key> <e> <n>: "–" # en-dash
