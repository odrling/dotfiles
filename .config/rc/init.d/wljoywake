#!/sbin/openrc-run
XDG_STATE_HOME="${XDG_STATE_HOME:-${HOME}/.local/state}"
LOGFILE="${XDG_STATE_HOME}/rc/${RC_SVCNAME}.log"

name="wljoywake"
description="keep screen on when joystick is used"

command="wljoywake"
command_args="-t 30"
output_log="${LOGFILE}"
error_log="${LOGFILE}"
supervisor=supervise-daemon
