#!/sbin/openrc-run
XDG_STATE_HOME="${XDG_STATE_HOME:-${HOME}/.local/state}"
LOGFILE="${XDG_STATE_HOME}/rc/${RC_SVCNAME}.log"

name="swaybg"
description="desktop wallpaper"

command="swaybg"
command_args="-i ${HOME}/.wallpaper"
output_log="${LOGFILE}"
error_log="${LOGFILE}"
supervisor=supervise-daemon
