#!/bin/bash

die() {
	echo -e " ${NOCOLOR-\e[1;31m*\e[0m }${*}" >&2
	exit 1
}

einfo() {
	echo -e " ${NOCOLOR-\e[1;32m*\e[0m }${*}" >&2
}

ewarn() {
	echo -e " ${NOCOLOR-\e[1;33m*\e[0m }${*}" >&2
}

dots submodule update --init "${HOME}"

if command -v nvim > /dev/null 2>&1; then
    einfo "updating nvim"
    nvim --headless "+lua dots_post_update()" +qa || ewarn "nvim ended with status $?"
    echo # nvim sometimes ends without a newline
fi

if command -v scdoc > /dev/null 2>&1; then
    einfo "updating man pages"
    mkdir -p ~/.local/share/man/man1
    scdoc < ~/.local/share/doc/dots.1.scd > ~/.local/share/man/man1/dots.1

    command -v mandb > /dev/null 2>&1 && mandb --user-db ~/.local/share/man
fi

if command -v pipx > /dev/null 2>&1; then
    einfo "updating pipx packages"
    pipx upgrade-all || die "pipx update failed"
fi

if command -v uv > /dev/null 2>&1; then
    einfo "updating uv tools"
    uv tool upgrade --all || die "pipx update failed"
fi

if [ -d ~/.mozilla ]; then
    mv -v ~/.mozilla/* "${XDG_CONFIG_HOME}/mozilla/"
    rm -rv ~/.mozilla
fi

if [ -d "${XDG_CONFIG_HOME}/mozilla" ]; then
    for i in "${XDG_CONFIG_HOME}"/mozilla/firefox/*/; do
        einfo "installing Betterfox in ${i}"
        cp -v "${XDG_CONFIG_HOME}"/mozilla/Betterfox/user.js "${i}"
        cat "${XDG_CONFIG_HOME}"/mozilla/user_pref.js >> "${i}/user.js"
    done
else
    ewarn "not installing Betterfox because firefox config directory wasn't found"
fi
